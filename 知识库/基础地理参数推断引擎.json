        "tectonic_implication": "古老侵蚀面或轻微抬升区",
        "primary_parent_material": ["沉积岩(砂岩/页岩)", "花岗岩类(风化)"],
        "secondary_parent_material": ["变质岩"],
        "confidence": 0.55,
