    ],

    "6.2 气候对表层母质的二次改造": {
      "description": "气候通过风化作用改造表层母质的矿物组成。对WRB土壤推断有重要意义。",
      "rules": [
        { "climate_koppen": ["Af", "Am"], "effect": "任何母质→强烈化学风化→形成厚层铁铝风化壳(>5m)。花岗岩→高岭土+石英砂+铁壳；玄武岩→铝土矿+铁壳。", "surface_override": "风化壳(铁铝质)" },
        { "climate_koppen": ["Aw"], "effect": "季节性风化→干季铁氧化物脱水硬化→形成铁壳层(硬磐)。风化壳厚度次于Af区。", "surface_override": "铁壳/钙积风化壳" },
        { "climate_koppen": ["Cfa", "Cwa"], "effect": "中等风化→花岗岩风化壳可厚达10-30m→高岭土发育。石灰岩区→喀斯特溶蚀残余黏土。", "surface_override": "高岭土风化壳/红色石灰土" },
        { "climate_koppen": ["Cfb"], "effect": "较弱化学风化→母质影响大。花岗岩→砂质酸性土；石灰岩→棕壤；黄土→深厚壤质棕壤。", "surface_override": "弱风化残积层" },
        { "climate_koppen": ["BSk", "BWk"], "effect": "物理风化为主+碳酸钙在剖面中积聚→钙积层。蒸发强烈区→盐渍化。", "surface_override": "钙积层/石膏层/盐壳" },
        { "climate_koppen": ["ET"], "effect": "冻融物理风化→碎石遍布。有机质分解极慢→泥炭积累。", "surface_override": "冻融碎石/泥炭" }
      ]
    }
  },

  "七、排水条件推断": {
    "description": "由地形+坡度+气候综合推断排水等级。排水条件直接影响土壤类型(Gleysols潜育化、Histosols泥炭化等)。",
    "rules": [
      { "terrain_type": ["high_mountain", "low_mountain"], "slope": ">15°", "drainage": "excessive", "note": "陡坡→排水极快→土壤薄→Leptosols" },
      { "terrain_type": ["hill"], "slope": "5-15°", "drainage": "good", "note": "坡地→排水良好" },
      { "terrain_type": ["plain", "plateau"], "slope": "<3°", "drainage": "moderate", "note": "平地→排水适中" },
      { "terrain_type": ["basin"], "slope": "<2°", "drainage": "poor", "note": "盆地→水聚集→排水不良→潜育化风险" },
      { "terrain_type": ["floodplain"], "slope": "<1°", "drainage": "poor_to_very_poor", "note": "河漫滩→地下水位高→强烈潜育化→Gleysols" },
      { "terrain_type": ["coastal"], "slope": "<1°", "drainage": "moderate_to_poor", "note": "海岸平地→排水受潮汐和地下水位影响" },
      { "climate_koppen": ["Af", "Am", "Cfb"], "effect": "年降水>1200mm + 排水moderate → 可能积水→排水等级下调一级" },
      { "climate_koppen": ["BWh", "BWk", "BSk"], "effect": "年降水<400mm → 蒸发>降水 → 排水等级实际上调一级(因极少积水)" }
    ]
  },

  "八、完整级联推导管线": {
    "description": "从用户的地图OC到最终全部诊断输出的完整管线。每个步骤的输入=上一步的输出，用户无需手动填入任何中间参数。",

    "pipeline": [
      {
        "step": 1,
        "name": "基础参数采集",
        "source": "用户地图OC",
        "outputs": ["latitude", "altitude", "slope", "aspect", "land_sea_position", "terrain_type", "ocean_current?"],
        "auto_flag": false
      },
      {
        "step": 2,
        "name": "气压带+盛行风向判定",
        "engine": "本引擎(一、二节)",
        "inputs": ["latitude", "land_sea_position"],
        "outputs": ["pressure_belt", "prevailing_wind_direction", "wind_onshore_or_offshore"]
      },
      {
        "step": 3,
        "name": "年均温+年温差推断",
        "engine": "本引擎(三节)",
        "inputs": ["latitude", "altitude", "land_sea_position", "terrain_type"],
        "outputs": ["T_annual_mean", "ΔT_annual"]
      },
      {
        "step": 4,
        "name": "12个月均温生成",
        "engine": "本引擎(四节)",
        "inputs": ["T_annual_mean", "ΔT_annual", "latitude(判定半球)", "ocean_current?"],
        "outputs": ["monthly_temps[12]"]
      },
      {
        "step": 5,
        "name": "年降水+季节分配推断",
        "engine": "本引擎(五节)",
        "inputs": ["pressure_belt", "land_sea_position", "wind_onshore_or_offshore", "altitude", "slope", "aspect", "ocean_current?"],
        "outputs": ["P_annual", "monthly_precip[12]", "precip_seasonality_pattern"]
      },
      {
        "step": 6,
        "name": "成土母质推断",
        "engine": "本引擎(六节)",
        "inputs": ["terrain_type", "climate_koppen(初步)"],
        "outputs": ["parent_material", "surface_weathering_override"]
      },
      {
        "step": 7,
        "name": "排水条件推断",
        "engine": "本引擎(七节)",
        "inputs": ["terrain_type", "slope", "climate_koppen(初步)"],
        "outputs": ["drainage_class"]
      },
      {
        "step": 8,
        "name": "柯本气候类型判定",
        "engine": "柯本气候类型判定矩阵.md",
        "inputs": ["monthly_temps[12]", "P_annual", "monthly_precip[12]"],
        "outputs": ["koppen_type", "climate_name_zh", "koppen_subtype"]
      },
      {
        "step": 9,
        "name": "Holdridge生命带+潜在植被推断",
        "engine": "生态-农业-土壤综合诊断系统.md(第一节)",
        "inputs": ["monthly_temps[12]", "P_annual"],
        "outputs": ["BT(biotemperature)", "PET", "PER", "latitudinal_belt", "humidity_province", "life_zone", "potential_vegetation"]
      },
      {
        "step": 10,
        "name": "【水文】径流生成",
        "engine": "水文推断引擎.json(第一节)",
        "inputs": ["P_annual", "monthly_precip[12]", "slope", "drainage_class", "life_zone", "permafrost"],
        "outputs": ["C_runoff", "R_annual(runoff_depth)", "river_regime_type", "monthly_discharge_factors"]
      },
      {
        "step": 11,
        "name": "【水文】河流网络生成",
        "engine": "水文推断引擎.json(第二节)",
        "inputs": ["altitude(DEM)", "slope", "R_annual", "terrain_type", "koppen_type", "parent_material"],
        "outputs": ["river_positions[strahler_order]", "river_widths", "channel_pattern", "perennial_or_seasonal", "drainage_density"]
      },
      {
        "step": 12,
        "name": "【水文】湖泊生成",
        "engine": "水文推断引擎.json(第三节)",
        "inputs": ["terrain_type", "altitude(DEM凹地)", "P_annual", "PET", "parent_material", "koppen_type"],
        "outputs": ["lake_positions", "lake_type", "lake_area_km2", "lake_depth_m", "salinity_ppt", "pH"]
      },
      {
        "step": 13,
        "name": "【水文】母质/土壤修正",
        "engine": "水文推断引擎.json(第四节+第六节overrides)",
        "inputs": ["river_positions", "lake_positions", "parent_material", "koppen_type"],
        "outputs": ["parent_material_override(河漫滩→冲积物等)", "soil_suggestion_local"]
      },
      {
        "step": 14,
        "name": "农作物适宜性推荐",
        "engine": "生态-农业-土壤综合诊断系统.md(第二节, FAO AEZ)",
        "inputs": ["koppen_type", "soil_texture(from_parent_override)", "growing_season_days", "P_annual", "altitude", "irrigation_potential(from_水文)"],
        "outputs": ["S1_crops", "S2_crops", "S3_crops", "N_crops", "cash_crops"]
      },
      {
        "step": 15,
        "name": "土壤类型推断(含水文修正)",
        "engine": "生态-农业-土壤综合诊断系统.md(第三节, WRB) + 水文推断引擎(第六节overrides)",
        "inputs": ["koppen_type", "altitude", "slope", "drainage_class", "parent_material(已修正)", "potential_vegetation", "距河流距离", "距湖泊距离"],
        "outputs": ["primary_soil_wrb", "zh_name", "confidence", "alternative_soils", "diagnostic_horizon"]
      },
      {
        "step": 16,
        "name": "野生动物推断",
        "engine": "气候-野生动物属库.json",
        "inputs": ["koppen_type"],
        "outputs": ["animals[{genus, name_zh, body_size, diet, social_structure, activity_rhythm, special_adaptation, endemic}]"]
      },
      {
        "step": 17,
        "name": "原产植物推断",
        "engine": "气候-原产植物库.json",
        "inputs": ["koppen_type"],
        "outputs": ["plants_by_habitat[{habitat, plants[{name, uses, rarity}]}]"]
      },
      {
        "step": 18,
        "name": "矿产推断(含砂矿+蒸发岩)",
        "engine": "矿产分布规则库.json + 水文推断引擎(第六节mineral_overrides)",
        "inputs": ["terrain_type", "parent_material(已修正)", "koppen_type", "river_positions", "lake_positions", "lake_salinity"],
        "outputs": ["minerals[{name, deposit_type, confidence}]", "tech_path_recommendation"]
      },
      {
        "step": 19,
        "name": "【水文】文明选址评分",
        "engine": "水文推断引擎.json(第五节)",
        "inputs": ["river_positions", "river_widths", "river_slope", "lake_positions", "koppen_type", "terrain_type"],
        "outputs": ["city_suitability_score(0-100)", "top_city_location_candidates", "navigability_class", "irrigation_potential", "flood_risk"]
      },
      {
        "step": 20,
        "name": "【城镇】发展潜力综合评估",
        "engine": "城镇发展潜力评估引擎.json",
        "inputs": ["koppen_type", "monthly_temps", "P_annual", "growing_season_days", "primary_soil_wrb", "S1_S2_S3_crops", "irrigation_potential", "river_positions+width+navigability", "lake_positions", "terrain_type", "slope", "land_sea_position", "parent_material", "mineral_list", "potential_vegetation", "flood_risk"],
        "outputs": ["total_score(0-100)", "dimension_scores[7维]", "development_stage(0-5)", "population_estimate", "primary_specialization", "secondary_specializations", "key_buildings", "growth_forecast", "inter_city_relationships"]
      }
    ],

    "iteration_note": "柯本判定(step8)需要月降水季节分配模式，而月降水季节分配(step5)又部分依赖柯本类型的预先判断→先用基准降水模式生成初步月降水→判定柯本→如有矛盾则用柯本类型修正降水→最多迭代2次收敛。水文推断(step10-13)在柯本和Holdridge确定后执行，因为径流系数依赖植被类型，河流类型依赖气候。母质修正(step13)的反灌到土壤推断(step15)。文明选址(step19)是管线的最后一个推断步骤——此时所有自然环境参数已知。"
  },

